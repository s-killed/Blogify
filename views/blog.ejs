<!DOCTYPE html>
<html lang="en">

    <head>
        <%- include('./partials/head') %>
        <title>Blog</title>
    </head>

    <body>

        <%- include('./partials/nav') %>

        <div class="container mt-4">
            <h1><%= blog.title %></h1>
            <img src="<%= blog.coverImageURL %>"
                style="width: 50vw; height: auto;" alt>
            <!-- Add this near your blog title or content -->
            <% if (locals.user && locals.user._id === blog.createdBy._id.toString()) { %>
                <div class="mt-3 mb-3">
                    <a href="/blog/edit/<%= blog._id %>" class="btn btn-sm btn-warning">Edit Blog</a>
                </div>
            <% } %>

            <p class="mt-3" style="font-weight: 600;">
                <img src="<%= blog.createdBy.profileImageUrl  %>"
                    width="40px" class="me-1">
                <a> By: </a>
                <%= blog.createdBy.fullName %>
            </p>
            <p class="mt-3"
                style="text-align: justify; font-size: clamp(16px, 1.5vw, 24px);">
                <%= blog.body %>
            </p>
        </div>

        <div class="container mt-4">
            <h2>Comments(<%= comments.length %>)</h2>
            <% if (locals.user) { %>
            <form action="/blog/comment/<%= blog._id %>" method="post">
                <div class="mb-3">
                    <textarea
                        name="content"
                        class="form-control"
                        placeholder="Enter Your Comment"
                        rows="3"></textarea>
                    <button type="submit"
                        class="btn btn-primary mt-2">Comment</button>

                </div>
            </form>
            <% } else { %>
            <!-- Show this line if user is NOT logged in -->
            <p class="text-muted">Sign in to comment</p>
            <% } %>

            <div class="mt-3">
                <% comments.forEach(comment => { %>

                <div class="mt-3" style="font-weight: 450;">
                    <% if (comment.createdBy) { %>
                    <!-- Show the real user data if they still exist -->
                    <img src="<%= comment.createdBy.profileImageUrl %>"
                        width="25px" class="me-1">
                    <%= comment.createdBy.fullName %>:
                    <% } else { %>
                    <!-- Fallback if the user was deleted -->
                    <img src="/images/defaultimg.png" width="25px" class="me-1">
                    <span class="text-muted italic">Deleted User</span>:
                    <% } %>

                    <pre class="mt-1"><%= comment.content %></pre>
                </div>

                <% }) %>
            </div>

        </div>

        <%- include('./partials/scripts') %>

    </body>
</html>
